{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "g++ -g ${workspaceFolder}/main.cpp -o ${workspaceFolder}/build/program -I/usr/include/opencv4 -lopencv_core -lopencv_imgproc -lopencv_highgui -lopencv_imgcodecs",
            "options": {
                "shell": {
                    "executable": "/bin/bash",
                    "args": ["-l", "-c"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}